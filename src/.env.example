# Environment variables example file
# Copy this file as .env.local in /src/ and configure the correct values

NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
# Keycloak realm
NEXT_PUBLIC_KEYCLOAK_REALM=realm_name
# Keycloak client ID
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=client_id
NEXT_PUBLIC_KEYCLOAK_CLIENT_SECRET=secret_client_id
# API URL
NEXT_PUBLIC_ACLIMATE_API_URL=http://127.0.0.1:8000
# Auth API URL
NEXT_PUBLIC_AUTH_API_URL=http://localhost:3001/api
# Frontend base URL
NEXT_PUBLIC_ACLIMATE_API_FRONTEND_URL=http://127.0.0.1:9000
NEXT_PUBLIC_ACLIMATE_APP_ID=1
NEXT_PUBLIC_COUNTRY_NAME='CountryName'
NEXT_PUBLIC_GEOSERVER_URL=https://geoserver.com
NEXT_PUBLIC_SHOW_STATIONS_MODULE=true
NEXT_PUBLIC_SHOW_USERS_MODULE=true